{
  "name": "agent-live2d",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "backend:dev": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8001 --reload",
    "smoke:backend": "python -c \"from app.main import app; print('app-import-ok', bool(app))\"",
    "smoke:release": "node scripts/release-smoke.mjs",
    "smoke:startup": "node scripts/startup-port-smoke.mjs",
    "docker:up": "docker compose up --build",
    "docker:up:d": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app qdrant",
    "build": "tsc -b && vite build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "lint": "eslint .",
    "preview": "vite preview",
    "local:up": "node scripts/local-experience.mjs up",
    "local:down": "node scripts/local-experience.mjs down",
    "local:check": "node scripts/local-experience.mjs check",
    "local:web": "node scripts/local-experience.mjs web",
    "local:web:only": "node scripts/local-experience.mjs web-only",
    "local:desktop": "node scripts/local-experience.mjs desktop",
    "local:desktop:only": "node scripts/local-experience.mjs desktop-only",
    "desktop:doctor": "node scripts/desktop-doctor.mjs",
    "tauri:dev": "node scripts/tauri-dev-safe.mjs",
    "tauri:dev:check": "node scripts/tauri-dev-safe.mjs --check-only",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.95.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^7.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  }
}
