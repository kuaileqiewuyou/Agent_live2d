APP_NAME=Agent Live2D Backend
APP_ENV=development
DEBUG=true
API_PREFIX=/api
HOST=0.0.0.0
PORT=8001

DATABASE_URL=sqlite+aiosqlite:///./data/app.db
DATA_DIR=./data

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=long_term_memories

EMBEDDING_BACKEND=simple
EMBEDDING_DIMENSIONS=64

SHORT_TERM_MESSAGE_LIMIT=12
SUMMARY_TRIGGER_MESSAGE_COUNT=12
DEFAULT_STREAM_CHUNK_SIZE=32
