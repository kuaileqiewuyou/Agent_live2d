{
  "$schema": "../gen/schemas/capabilities.json",
  "identifier": "default",
  "description": "默认应用权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        "**"
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        "**"
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        "**"
      ]
    }
  ]
}
